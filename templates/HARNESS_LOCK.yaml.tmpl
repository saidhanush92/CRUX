    hash: sha256:dddd
  - path: .github/workflows/audit-site-deploy.yml
    hash: sha256:eeee
  - path: .github/workflows/trace-lint.yml
    hash: sha256:ffff

verification:                    # outcomes of the Gate 5 verification suite
  format_check: pass
  lint_check: pass
