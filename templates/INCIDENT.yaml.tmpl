# INCIDENT artifact — a violation of an approved REQ or ADR observed in production or CI.
# Usage: copy to docs/sdlc/incidents/INC-<n>.yaml. Cascades into CHG events and AMENDMENTS.
# Open via /crux-incident report — never hand-fabricate an incident id.

id: INC-001
title: Trace latency exceeded 200ms threshold for 8 consecutive requests in prod
violated:                        # required, REQ or ADR ids whose contract was broken
  - REQ-001                      # the latency budget
  - ADR-004                      # the index pagination contract
root_cause: |                    # plain-language explanation; do not copy a stack trace here
  trace-index loaded the full corpus into memory on each call instead of using the
  prefix-bounded query specified by ADR-004. The index module's lazy path was never
  exercised under load.
chg_events_opened:               # CHG ids spawned to fix the violation
  - CHG-014
prevention_tasks:                # TASK ids that will prevent recurrence
  - TASK-031                     # add load test that fails the build at >180ms p95
  - TASK-032                     # extract pagination invariant into a runtime assertion
amendment_ids:                   # AMENDMENT ids generated by amendment-writer for this incident
  - AMD-007
